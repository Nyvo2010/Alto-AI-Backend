# LLM Providers
MISTRAL_API_KEY=
GROQ_API_KEY=

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Server ports (optional — defaults shown)
API_PORT=8000
AGENT_PORT=8001

# CORS — comma-separated origins allowed to call the API
# Include your GitHub Pages frontend URL here
CORS_ORIGINS=https://nyvo2010.github.io,http://localhost:3000

# NOTE: Cloudflare Tunnel removed — expose ports via router/port-forwarding
# (e.g. forward external hostnames `api.alto-ai.dev` and `logs.alto-ai.tech`
# to the machine running this server)

# Logging
LOG_LEVEL=INFO
# LOG_LEVEL options: DEBUG, INFO, WARNING, ERROR

# Protect log streaming: set the same token in your Caddyfile (header injection)
LOG_STREAM_TOKEN=

# Tool secrets — add one block per tool as you build them
# DISCORD_BOT_TOKEN=
# TRELLO_CLIENT_ID=
# TRELLO_CLIENT_SECRET=
